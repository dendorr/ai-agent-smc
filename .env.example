# AI Agent SMC example environment
# Copy this file to .env and adjust values for your machine.
#
#   cp .env.example .env
#   source .env

# Project paths
# By default, config.py uses the repository root as AI_AGENT_BASE_DIR.
# Set this only if you want data/chroma/memory outside the repo.
# AI_AGENT_BASE_DIR=/home/your-user/ai-agent-smc
# COMPANY_DATA_DIR=/home/your-user/ai-agent-smc/data
# FINANCIAL_DATA_DIR=/home/your-user/ai-agent-smc/data/financial
# DRAWINGS_DATA_DIR=/home/your-user/ai-agent-smc/data/drawings
# DOCUMENTS_DATA_DIR=/home/your-user/ai-agent-smc/data/documents

# LLM backend
# Ollama development default:
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama-no-key

# Models
LLM_MODEL_MAIN=qwen2.5:7b
LLM_MODEL_FAST=qwen3:0.6b
EMBED_MODEL=nomic-embed-text

# Server
AGENT_PORT=8000
KIWIX_PORT=8080

# Chunking
CHUNK_SIZE=600
CHUNK_OVERLAP=60

# OCR
OCR_ENABLED=true
OCR_MODEL=glm-ocr
OCR_MIN_TEXT_LEN=15
OCR_PDF_PAGE_RASTER_DPI=200
OCR_PDF_MIN_TEXT_PER_PAGE=50
OCR_TIMEOUT_SECONDS=60

# Multi-step retrieval
MULTI_STEP_ENABLED=true
MULTI_STEP_MAX_ROUNDS=1
MULTI_STEP_MIN_CONTEXT_LEN=100

# Timeouts
LLM_TIMEOUT_SECONDS=180
LLM_ROUTING_TIMEOUT_SECONDS=30